# Example ladon config (YAML).
#
# Всё необязательно. Любое не указанное поле берётся из engine.Defaults()
# — это ровно то, с чем ладон ездит, когда -config вообще не задан.
#
# Скопировать: cp /opt/ladon/config.yaml.example /etc/ladon/config.yaml
# Передать в сервис: ladon -config /etc/ladon/config.yaml run <logfile>

# --- пути (обычно задаются через CLI, но можно и здесь) ---

# logfile: /var/log/dnsmasq.log
# manual_allow: /etc/ladon/manual-allow.txt
# manual_deny: /etc/ladon/manual-deny.txt

# --- probe backend ---

# Extensions — преднастроенные allow/deny-списки. См. /opt/ladon/extensions/README.md
# allow_extensions:
#   - ai
#   - twitch
#   - tiktok
# deny_extensions:
#   - ru-direct
# extensions_path: /opt/ladon/extensions   # default
# Note: старый ключ `extensions:` всё ещё принимается как alias для
# `allow_extensions:` (будет удалён в v0.6) — ladon напишет warning в журнал.

probe:
  mode: local          # local (default) | exit-compare
  timeout: 800ms       # TCP/TLS dial timeout
  cooldown: 5m         # минимальный интервал между probe одного домена
  concurrency: 8       # семафор для inline-probe из tailer
  # interval: 2s       # как часто ходит batch probe-worker
  # batch: 4           # сколько кандидатов за тик

  # --- exit-compare: добавляет remote-валидатор поверх локальной пробы ---
  # local FAIL + remote OK         = Hot (real block, exit confirms reachable)
  # local FAIL + remote FAIL       = Ignore (methodological FP)
  # local FAIL + remote unavailable = Hot (transport error → "no opinion", local stays)
  # Inline fast-path всегда только локальный — remote только в batch.
  # remote:
  #   url: https://my-probe-server.example.com/probe
  #   timeout: 2s
  #   auth_header: Authorization
  #   auth_value: Bearer mysecrettoken

# --- scorer: когда hot → cache ---

scorer:
  interval: 10m        # как часто scorer проходится
  window: 24h          # окно для подсчёта fails
  fail_threshold: 50   # порог fails для промоушна

# --- routing ---

ipset:
  name: ladon_engine        # ipset для probe-driven hot/cache
  manual_name: ladon_manual # ipset для manual-allow + extensions (populates dnsmasq'ом)
  interval: 30s             # safety-reconcile; горячие события триггерят немедленный sync

# --- TTL / freshness ---

hot_ttl: 24h           # срок жизни записи в hot_entries
dns_freshness: 6h      # возраст, после которого IP из dns_cache устаревает

# --- публикация ---

# publish_path: /opt/ladon/state/published-domains.txt
# publish_interval: 10s

# --- прочее ---

# ignore_peer: 10.10.0.1   # peer, чьи DNS-запросы игнорируются (gateway self)
